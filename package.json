{
  "name": "fullstack-monorepo-template",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --continue",
    "test": "turbo run test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun scripts/run-static-checks.ts check",
    "check:fix": "bun scripts/run-static-checks.ts fix",
    "clean": "turbo run clean && bun exec \"rm -rf node_modules .turbo\"",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "concurrently": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.8.17",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "lefthook"
  ]
}
