{
  "name": "fullstack-monorepo-template",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.8",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "turbo": "^2.8.17",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "lefthook"
  ]
}
