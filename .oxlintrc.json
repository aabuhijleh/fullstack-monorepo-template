{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["*.gen.ts", "**/convex/_generated/**", "**/.claude/**", "**/.agents/**"],
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
