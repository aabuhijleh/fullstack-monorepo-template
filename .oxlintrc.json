{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["*.gen.ts", "**/_generated/**", "**/.agents/**", "**/.claude/**"],
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react"],
  "jsPlugins": [{ "name": "eslint-react-hooks", "specifier": "eslint-plugin-react-hooks" }],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "eslint-react-hooks/component-hook-factories": "warn",
    "eslint-react-hooks/config": "warn",
    "eslint-react-hooks/error-boundaries": "warn",
    "eslint-react-hooks/gating": "warn",
    "eslint-react-hooks/globals": "warn",
    "eslint-react-hooks/immutability": "warn",
    "eslint-react-hooks/incompatible-library": "warn",
    "eslint-react-hooks/preserve-manual-memoization": "warn",
    "eslint-react-hooks/purity": "warn",
    "eslint-react-hooks/refs": "warn",
    "eslint-react-hooks/set-state-in-effect": "warn",
    "eslint-react-hooks/set-state-in-render": "warn",
    "eslint-react-hooks/static-components": "warn",
    "eslint-react-hooks/unsupported-syntax": "warn",
    "eslint-react-hooks/use-memo": "warn"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "reportUnusedDisableDirectives": "warn"
  }
}
