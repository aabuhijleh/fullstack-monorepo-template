{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "packages/ui/src/styles/globals.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": [
    "*.gen.ts",
    "**/convex/_generated/**",
    "**/.claude/**",
    "**/.agents/**"
  ]
}
